# ============================================
# BANCO DE DADOS (Railway)
# ============================================
# Cole aqui a connection string do Railway
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ============================================
# AUTENTICAÇÃO (Clerk)
# clerk.com → criar conta → copiar as chaves
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_COLE_AQUI
CLERK_SECRET_KEY=sk_test_COLE_AQUI
CLERK_WEBHOOK_SECRET=whsec_COLE_AQUI

# Rotas de auth
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ============================================
# PAGAMENTOS (Stripe)
# dashboard.stripe.com → Developers → API keys
# ============================================
STRIPE_SECRET_KEY=sk_test_COLE_AQUI
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_COLE_AQUI
STRIPE_WEBHOOK_SECRET=whsec_COLE_AQUI

# IDs dos planos no Stripe (criar em Products)
STRIPE_STARTER_PRICE_ID=price_COLE_AQUI
STRIPE_GROWTH_PRICE_ID=price_COLE_AQUI

# ============================================
# E-MAIL (Resend)
# resend.com → criar conta → API Keys
# ============================================
RESEND_API_KEY=re_COLE_AQUI
EMAIL_FROM="Claro Treina <noreply@seudominio.com.br>"

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
